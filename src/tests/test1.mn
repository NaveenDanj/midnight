func max(int a , int b , int c) int {
    if (a == b) {
        return a;
    } else {
        if(b) {
            return c;
        }
        return b;
    }
    return b;
}

func fibbonachi(int num) int {
    var int counter = 0;

    while(counter < num) {

        if(counter == 0) {
            return 0;
        } else {
            return counter;
        }
    }

    return counter;
}